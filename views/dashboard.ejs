<%- include('partials/header') %>

<div class="container">
  <div class="page-header">
    <h1>✦ Sanctum of <span><%= user.character_name %></span></h1>
    <div>
      <span class="badge badge-<%= user.role %>" style="font-size:0.85rem;"><%= user.role %></span>
      <span style="margin-left:8px;color:var(--text-muted);"><%= user.race %> <%= user.class %></span>
    </div>
  </div>

  <div class="grid-4" style="margin-bottom:2rem;">
    <div class="card stat-card">
      <div class="stat-value"><%= Math.round(dkpTotal) %></div>
      <div class="stat-label">Total DKP</div>
    </div>
    <div class="card stat-card">
      <div class="stat-value" style="color:var(--gold);"><%= upcomingEvents ? upcomingEvents.filter(e => !e.checked_in).length : 0 %></div>
      <div class="stat-label">Upcoming Raids</div>
    </div>
    <div class="card stat-card">
      <div class="stat-value" style="color:var(--success);"><%= attendedEvents ? attendedEvents.length : 0 %></div>
      <div class="stat-label">Raids Attended</div>
    </div>
    <div class="card stat-card">
      <div class="stat-value" style="color:var(--blue);">+5</div>
      <div class="stat-label">DKP per Raid</div>
    </div>
  </div>

  <div class="dashboard">
    <div class="card">
      <div class="card-header"><h2>📅 Upcoming Events</h2><a href="/events" class="btn btn-secondary btn-sm">All Events</a></div>
      <% if (upcomingEvents && upcomingEvents.length > 0) { %>
        <% upcomingEvents.forEach(e => { %>
        <div class="event-item">
          <div class="event-info">
            <h4><%= e.title %></h4>
            <p><%= e.location || 'TBD' %> · <%= new Date(e.event_date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
          </div>
          <div class="event-meta">
            <% if (e.checked_in) { %>
              <span class="badge badge-checked">Checked In</span>
            <% } else { %>
              <span class="badge badge-pending">Not Checked</span>
            <% } %>
          </div>
        </div>
        <% }) %>
      <% } else { %>
        <p style="color:var(--text-muted);text-align:center;padding:2rem 0;">No upcoming events scheduled.</p>
      <% } %>
    </div>

    <div class="card">
      <div class="card-header"><h2>💰 Recent DKP</h2><a href="/dkp" class="btn btn-secondary btn-sm">Full History</a></div>
      <% if (recentDkp && recentDkp.length > 0) { %>
        <% recentDkp.forEach(d => { %>
        <div class="dkp-entry">
          <span><%= d.reason %></span>
          <span class="dkp-points dkp-positive">+<%= Math.round(d.points) %></span>
        </div>
        <% }) %>
      <% } else { %>
        <p style="color:var(--text-muted);text-align:center;padding:2rem 0;">Earn DKP by attending raids!</p>
      <% } %>
    </div>
  </div>

  <div class="card" style="margin-top:1.5rem;">
    <div class="card-header"><h2>📜 Recent Raid History</h2></div>
    <% if (attendedEvents && attendedEvents.length > 0) { %>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Event</th><th>Location</th><th>Date</th><th>Checked In</th><th>Notes</th></tr></thead>
          <tbody>
            <% attendedEvents.forEach(e => { %>
            <tr>
              <td><strong><%= e.title %></strong></td>
              <td><%= e.location || '—' %></td>
              <td><%= new Date(e.event_date).toLocaleDateString() %></td>
              <td><span class="badge badge-checked">✓ <%= new Date(e.checked_in_at).toLocaleString() %></span></td>
              <td style="color:var(--text-muted);font-size:0.85rem;"><%= e.notes || '—' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p style="color:var(--text-muted);text-align:center;padding:2rem 0;">No raids attended yet. Check the Events page for upcoming raids!</p>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
